# Copie para .env e preencha. O .env NÃO é commitado (ver .gitignore).

# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# MongoDB
MONGO_URI=mongodb://user:pass@host:27017
MONGO_DB=wynn_guild

# WynnCraft
WYNN_GUILD_PREFIX=
# Opcional: se preenchido, a identificação da guilda passa a usar o UUID, que é
# imutável, em vez do prefixo (que o dono pode trocar a qualquer momento).
WYNN_GUILD_UUID=
# Opcional: eleva o limite de 50 para 120 req/min. Deixe vazio se não tiver.
WYNN_API_KEY=

# Guilda da black-list: quem for membro dela leva o cargo de banido no registro.
# Os valores abaixo já são o padrão embutido (Guardians of Wynn).
WYNN_BLACKLIST_GUILD_PREFIX=GsW
WYNN_BLACKLIST_GUILD_UUID=f7e7cc4e-212d-422f-a3e6-744a8689b108

# Healthcheck HTTP (Easypanel). Porta interna do container.
PORT=8080

# Domínio público do bot (sem barra no fim). Necessário para o /modpack, que
# serve o mods.rar em ${PUBLIC_URL}/modpack. Deve bater com o Host das labels do
# Traefik no docker-compose.yml. Em produção, defina na aba Environment do Dokploy.
PUBLIC_URL=https://modpack.battomic.com

# Emotes customizados do servidor (formato <:nome:id> ou <a:nome:id> se animado).
# Sem valor, cai no fallback Unicode. Ex. do emote de guerra no painel de info:
EMOJI_WAR=
